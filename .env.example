# Configuración del Proxy
# El código de país se agrega automáticamente según tu selección
# NO incluyas __cr.XX en el username, se agrega automáticamente
PROXY_PROTOCOL=http
PROXY_HOST=gw.dataimpulse.com
PROXY_PORT=823
PROXY_USERNAME=tu_usuario_aqui
PROXY_PASSWORD=tu_password_aqui

# Límite del proxy contratado (en GB)
# Cambia este valor según tu plan
PROXY_LIMIT_GB=1
